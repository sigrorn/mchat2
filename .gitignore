# Dependencies
node_modules/
.pnp.*
.yarn/

# Build output
dist/
dist-ssr/
build/
*.local
*.tsbuildinfo
# #302: tsc -b type-checks the root .ts config files (vite/vitest/
# playwright) and emits their unused transpiled output into this
# scratch dir, instead of next to the sources where the stale .js
# would shadow the .ts. Vite/Vitest/Playwright load .ts natively.
.tsbuild-node/

# #317: the build counter now lives in package.json's version field.
# Ignored defensively in case an old bump-script version regenerates it.
/.build-counter.json

# Tauri / Rust
src-tauri/target/
src-tauri/Cargo.lock.bak

# Editor / IDE
.vscode/*
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Emacs backups / autosaves
\#*\#
*~

# OS
.DS_Store
Thumbs.db

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Test output
coverage/
.nyc_output/
playwright-report/
test-results/
playwright/.cache/

# Env
.env
.env.*
!.env.example

# SQLite dev databases
*.db
*.db-journal
*.sqlite
*.sqlite-journal
src-tauri/gen/
